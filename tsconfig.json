{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
        "test-data": ["./test-data/index.ts"],
        "fixtures": ["./fixtures/index.ts"],
      }
  },
  "include": ["test-cases/**/*.ts", "pages/**/*.ts", "fixtures/**/*.ts", "test-data/**/*.ts", "playwright.config.ts"]
} 